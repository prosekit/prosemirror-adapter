{
  "name": "@prosemirror-adapter/monorepo",
  "type": "commonjs",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Monorepo for ProseMirror Adapter",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc -b",
    "commit": "git-cz",
    "ex": "pnpm --filter=e2e start",
    "test": "pnpm run build && pnpm --filter=e2e test",
    "test:install": "pnpm --filter=e2e test:install",
    "changeset": "changeset",
    "lint": "pnpm run lint:eslint && pnpm run lint:prettier && pnpm run lint:knip",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:knip": "knip",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier && pnpm run fix:ts",
    "fix:eslint": "eslint . --fix",
    "fix:prettier": "prettier --write .",
    "fix:ts": "monorepo-typescript-references fix",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ocavue/eslint-config": "^4.3.5",
    "@ocavue/tsconfig": "^0.7.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "monorepo-typescript-references": "^1.1.1",
    "pkg-pr-new": "^0.0.66",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "~5.9.3"
  }
}
